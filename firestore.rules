rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Followers subcollection
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }

      // Following subcollection
      match /following/{followedId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Trips collection
    match /trips/{tripId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;

      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.participantIds
            || resource.data.isPublic == true);

      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            // Allow non-owner to add THEMSELVES to participantIds (invitation acceptance)
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantIds', 'updatedAt'])
                && request.auth.uid in request.resource.data.participantIds
                && !(request.auth.uid in resource.data.participantIds)));

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Expenses subcollection — granular rules
      match /expenses/{expenseId} {
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds);

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;

        allow update, delete: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || resource.data.payerId == request.auth.uid
              || resource.data.createdBy == request.auth.uid);
      }

      // Media subcollection — granular rules
      match /media/{mediaId} {
        // Read access: trip owner, participants, anyone when the trip itself is public,
        // OR anyone when THIS media doc is marked public (per-media visibility). The
        // per-media branch is what lets Explore's collectionGroup query return public
        // photos even from a private parent trip.
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds
              || get(/databases/$(database)/documents/trips/$(tripId)).data.isPublic == true
              || resource.data.isPublic == true);

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds
          && request.resource.data.uploadedBy == request.auth.uid;

        allow update, delete: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || resource.data.uploadedBy == request.auth.uid);

        // Likes subcollection under media
        match /likes/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Itinerary subcollection — explicit rules
      match /itinerary/{docId} {
        allow read, write: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds);
      }
    }

    // Notifications collection
    match /notifications/{userId}/items/{notificationId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['type', 'message', 'read', 'createdAt'])
        && request.resource.data.type is string
        && request.resource.data.read == false;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Invitations collection
    match /invitations/{invitationId} {
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.ownerId == request.auth.uid;

      allow read: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
            || (resource.data.toEmail == request.auth.token.email
                && resource.data.toUserId == ''
                && resource.data.status == 'pending'));

      allow update: if request.auth != null
        && (resource.data.toUserId == request.auth.uid
            || (resource.data.toEmail == request.auth.token.email
                && resource.data.toUserId == ''
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['toUserId'])
                && request.resource.data.toUserId == request.auth.uid));

      allow delete: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
    }

    // Verification log — append-only immutable ledger
    match /verificationLog/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      // No update or delete — immutable
    }

    // Invite codes — short bearer tokens mapping a code to a tripId.
    // Read: any authenticated user (lookup during join flow).
    // Create: any authenticated user may claim a code doc they own.
    //   NOTE: we cannot get() the trip inside a writeBatch (pre-batch state
    //   has no trip yet), so the rule is intentionally lenient. Security is
    //   preserved because joinByCode only ever adds the CALLER to participantIds
    //   via the existing trip self-join rule — an attacker pointing a code at
    //   someone else's trip cannot use it to gain access to that trip.
    // Delete: only the original creator (trip owner at the time of creation).
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.tripId is string
        && request.resource.data.keys().hasOnly(['tripId', 'createdBy', 'createdAt']);
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
      // No update — codes are immutable once created.
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
