rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Followers subcollection
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }

      // Following subcollection
      match /following/{followedId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Trips collection
    match /trips/{tripId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;

      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.participantIds
            || resource.data.isPublic == true);

      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            // Allow non-owner to add THEMSELVES to participantIds (invitation acceptance)
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantIds', 'updatedAt'])
                && request.auth.uid in request.resource.data.participantIds
                && !(request.auth.uid in resource.data.participantIds)));

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Expenses subcollection — granular rules
      match /expenses/{expenseId} {
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds);

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;

        allow update, delete: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || resource.data.payerId == request.auth.uid
              || resource.data.createdBy == request.auth.uid);
      }

      // Media subcollection — granular rules
      match /media/{mediaId} {
        // Read access. IMPORTANT: per-media `isPublic` MUST be the first OR branch so
        // the collectionGroup query used by the Explore feed short-circuits before any
        // `get()` calls fire. Firestore caps access calls at 20 per query — evaluating
        // a trip `get()` once per matched doc blows that cap and also errors on
        // orphaned docs (trips that were deleted). Keeping this branch first means the
        // Explore hot path performs zero `get()` calls; only in-app gallery reads of
        // private media evaluate the trip-scoped branches.
        allow read: if request.auth != null
          && (resource.data.isPublic == true
              || get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds
              || get(/databases/$(database)/documents/trips/$(tripId)).data.isPublic == true);

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds
          && request.resource.data.uploadedBy == request.auth.uid;

        allow update, delete: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || resource.data.uploadedBy == request.auth.uid);

        // Likes subcollection under media
        match /likes/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Itinerary subcollection — explicit rules
      match /itinerary/{docId} {
        allow read, write: if request.auth != null
          && (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds);
      }
    }

    // Notifications collection
    match /notifications/{userId}/items/{notificationId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['type', 'message', 'read', 'createdAt'])
        && request.resource.data.type is string
        && request.resource.data.read == false;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Invitations collection
    match /invitations/{invitationId} {
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.ownerId == request.auth.uid;

      allow read: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
            || (resource.data.toEmail == request.auth.token.email
                && resource.data.toUserId == ''
                && resource.data.status == 'pending'));

      allow update: if request.auth != null
        && (resource.data.toUserId == request.auth.uid
            || (resource.data.toEmail == request.auth.token.email
                && resource.data.toUserId == ''
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['toUserId'])
                && request.resource.data.toUserId == request.auth.uid));

      allow delete: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
    }

    // Public media mirror — flat collection fed by the Explore feed.
    //
    // WHY THIS EXISTS: The Explore feed was originally a collectionGroup query
    // (`where('isPublic','==',true)`) against every trip's media subcollection.
    // Firestore's rule engine cannot short-circuit the OR in the subcollection's
    // read rule for list operations, so every candidate doc fired get() calls on
    // its parent trip — blowing the 20-access-call/query limit and throwing on
    // orphaned media whose parent trip had been deleted. Moving public media to
    // this flat top-level collection lets the rule be a single cheap
    // `resource.data`-only check with no get() calls.
    //
    // Writes are fanned out from mediaService.uploadMedia / deleteMedia and from
    // tripService.deleteTrip. Participant denormalization is unnecessary because
    // all docs in this collection are public by construction.
    match /publicMedia/{mediaId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.isPublic == true
        && request.resource.data.tripId is string
        && exists(/databases/$(database)/documents/trips/$(request.resource.data.tripId)/media/$(mediaId));

      allow delete: if request.auth != null
        && (resource.data.uploadedBy == request.auth.uid
            || resource.data.tripOwnerId == request.auth.uid);

      // No update — mirror docs are immutable. To change visibility, delete and
      // re-create.
    }

    // Verification log — append-only immutable ledger
    match /verificationLog/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      // No update or delete — immutable
    }

    // Invite codes — short bearer tokens mapping a code to a tripId.
    // Read: any authenticated user (lookup during join flow).
    // Create: any authenticated user may claim a code doc they own.
    //   NOTE: we cannot get() the trip inside a writeBatch (pre-batch state
    //   has no trip yet), so the rule is intentionally lenient. Security is
    //   preserved because joinByCode only ever adds the CALLER to participantIds
    //   via the existing trip self-join rule — an attacker pointing a code at
    //   someone else's trip cannot use it to gain access to that trip.
    // Delete: only the original creator (trip owner at the time of creation).
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.tripId is string
        && request.resource.data.keys().hasOnly(['tripId', 'createdBy', 'createdAt']);
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
      // No update — codes are immutable once created.
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
